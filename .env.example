# X / Twitter API credentials (OAuth 1.0a user context)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Or, if using OAuth 2.0 user context, set these instead:
# X_AUTH_TYPE=oauth2
# X_BEARER_TOKEN=
# X_REFRESH_TOKEN=
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# Telegram notification bot
TG_BOT_TOKEN=
TG_CHAT_ID=

# Posting safety switch. Anything other than "false" (case-insensitive) keeps
# the bot in dry-run mode. Default ON until the user explicitly turns it off.
DRY_RUN=true
